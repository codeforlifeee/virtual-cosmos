PORT=4000
FRONTEND_URL=http://localhost:5173
# Optional comma-separated list for additional allowed origins
FRONTEND_URLS=
# Optional: allow all Vercel preview origins (*.vercel.app)
ALLOW_VERCEL_ORIGINS=false
WORLD_WIDTH=1600
WORLD_HEIGHT=900
PROXIMITY_RADIUS=190
# MongoDB Atlas connection string (recommended for persistence)
# If your password contains special characters (like @, #, :), URL-encode them (for example @ -> %40).
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/virtual-cosmos?retryWrites=true&w=majority
# Optional: pass ICE server config for WebRTC (JSON array)
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]
